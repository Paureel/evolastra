# Development keeps the existing unauthenticated loopback workflow.
ASTERISM_ENV=development
ASTERISM_DEPLOYMENT_PROFILE=development
ASTERISM_DATABASE_URL=sqlite:///./data/asterism.db
ASTERISM_ARTIFACT_ROOT=./data/artifacts
ASTERISM_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ASTERISM_ALLOWED_HOSTS=127.0.0.1,localhost
ASTERISM_CAPTURE_CONTENT=false
