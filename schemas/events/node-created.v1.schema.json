{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starexplorer.local/schemas/events/node-created.v1.schema.json",
  "title": "Node created event v1",
  "allOf": [
    {
      "$ref": "./durable-event-envelope.v1.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "galaxy.analysis.node.created.v1"
        },
        "dataschema": {
          "const": "/schemas/events/node-created.v1.schema.json"
        },
        "subject": {
          "type": "string",
          "pattern": "^run/run_[0-9a-f-]+/node/node_[0-9a-f-]+$"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "node"
          ],
          "properties": {
            "node": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "id",
                "schema_version",
                "run_id",
                "node_type",
                "title",
                "status",
                "created_at",
                "promotion_reason"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^node_(?:[0-9a-f]{12}4[0-9a-f]{3}[89ab][0-9a-f]{15}|[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12})$"
                },
                "schema_version": {
                  "type": "integer",
                  "minimum": 1
                },
                "run_id": {
                  "type": "string",
                  "pattern": "^run_(?:[0-9a-f]{12}4[0-9a-f]{3}[89ab][0-9a-f]{15}|[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12})$"
                },
                "parent_node_id": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "pattern": "^node_(?:[0-9a-f]{12}4[0-9a-f]{3}[89ab][0-9a-f]{15}|[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12})$"
                },
                "node_type": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 100
                },
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 300
                },
                "status": {
                  "const": "created"
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "promotion_reason": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 1000
                }
              }
            }
          }
        }
      }
    }
  ]
}
